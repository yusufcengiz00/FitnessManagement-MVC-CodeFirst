@{
    ViewData["Title"] = "Yönetim Paneli";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Dashboard İstatistik Kartları -->
<div class="page-header">
    <div>
        <h1 class="page-title">
            <div class="admin-nav-icon icon-cyan" style="width:38px;height:38px;border-radius:10px;font-size:1rem;">
                <i class="fas fa-house"></i>
            </div>
            Yönetim Paneli
        </h1>
        <p class="page-subtitle">Sistem analizlerine ve modüllere hızlıca erişin.</p>
    </div>
    <div class="dashboard-live-badge">
        <span class="live-dot"></span>
        Sistem Canlı
    </div>
</div>

<!-- Karşılama Banner -->
<div class="welcome-banner">
    <div class="welcome-banner-glow"></div>
    <div class="welcome-content">
        <div class="welcome-avatar">
            <i class="fas fa-user-shield"></i>
        </div>
        <div>
            <h2 class="welcome-title">Merhaba, <span>Yönetici!</span></h2>
            <p class="welcome-sub">Tüm operasyonlarınızı buradan takip edip yönetebilirsiniz.</p>
        </div>
    </div>
    <div class="welcome-icon-deco">
        <i class="fas fa-dumbbell"></i>
    </div>
</div>

<!-- Modül Kartları -->
<div class="dashboard-grid">

    <!-- Raporlar -->
    <a asp-controller="Rapor" asp-action="Index" class="dash-card" style="--accent-color:#58a6ff; --accent-bg:rgba(56,139,253,0.08);">
        <div class="dash-card-top">
            <div class="dash-card-icon" style="background:rgba(56,139,253,0.12);color:#58a6ff;">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="dash-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
        <div class="dash-card-num">01</div>
        <h4 class="dash-card-title">Sistem Raporları</h4>
        <p class="dash-card-desc">Yaş ortalamaları, en pahalı ürünler ve detaylı salon analiz metrikleri.</p>
        <div class="dash-card-footer">
            <span>Raporları Görüntüle</span>
            <i class="fas fa-chevron-right"></i>
        </div>
    </a>

    <!-- Üye -->
    <a asp-controller="Uye" asp-action="Index" class="dash-card" style="--accent-color:#79c0ff; --accent-bg:rgba(31,111,235,0.08);">
        <div class="dash-card-top">
            <div class="dash-card-icon" style="background:rgba(31,111,235,0.12);color:#79c0ff;">
                <i class="fas fa-users"></i>
            </div>
            <div class="dash-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
        <div class="dash-card-num">02</div>
        <h4 class="dash-card-title">Üye Yönetimi</h4>
        <p class="dash-card-desc">Aktif üye listeleri, yeni üye kayıtları ve üyelik planı güncellemeleri.</p>
        <div class="dash-card-footer">
            <span>Üyeleri Yönet</span>
            <i class="fas fa-chevron-right"></i>
        </div>
    </a>

    <!-- Antrenör -->
    <a asp-controller="Antrenor" asp-action="Index" class="dash-card" style="--accent-color:#d2a8ff; --accent-bg:rgba(188,140,255,0.08);">
        <div class="dash-card-top">
            <div class="dash-card-icon" style="background:rgba(188,140,255,0.12);color:#d2a8ff;">
                <i class="fas fa-dumbbell"></i>
            </div>
            <div class="dash-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
        <div class="dash-card-num">03</div>
        <h4 class="dash-card-title">Antrenör İşlemleri</h4>
        <p class="dash-card-desc">Eğitmen kadrosu, uzmanlık alanları, kıdem ve tecrübe dağılımları.</p>
        <div class="dash-card-footer">
            <span>Antrenörleri Görüntüle</span>
            <i class="fas fa-chevron-right"></i>
        </div>
    </a>

    <!-- Salon -->
    <a asp-controller="Salon" asp-action="Index" class="dash-card" style="--accent-color:#e3b341; --accent-bg:rgba(228,166,15,0.08);">
        <div class="dash-card-top">
            <div class="dash-card-icon" style="background:rgba(228,166,15,0.12);color:#e3b341;">
                <i class="fas fa-building"></i>
            </div>
            <div class="dash-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
        <div class="dash-card-num">04</div>
        <h4 class="dash-card-title">Salon İşlemleri</h4>
        <p class="dash-card-desc">Tüm şubelerin adres bilgileri, doluluk oranları ve konum yönetimi.</p>
        <div class="dash-card-footer">
            <span>Salonları Görüntüle</span>
            <i class="fas fa-chevron-right"></i>
        </div>
    </a>

    <!-- Supplement -->
    <a asp-controller="Supplement" asp-action="Index" class="dash-card" style="--accent-color:#56d364; --accent-bg:rgba(46,160,67,0.08);">
        <div class="dash-card-top">
            <div class="dash-card-icon" style="background:rgba(46,160,67,0.12);color:#56d364;">
                <i class="fas fa-capsules"></i>
            </div>
            <div class="dash-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
        <div class="dash-card-num">05</div>
        <h4 class="dash-card-title">Supplement İşlemleri</h4>
        <p class="dash-card-desc">Stok takibi, fiyat listesi ve şubelere göre envanter dağılımı.</p>
        <div class="dash-card-footer">
            <span>Ürünleri Görüntüle</span>
            <i class="fas fa-chevron-right"></i>
        </div>
    </a>

    <!-- Hızlı Erişim Rapor -->
    <a asp-controller="Rapor" asp-action="ExportToPdf" class="dash-card dash-card-alt" style="--accent-color:#f85149; --accent-bg:rgba(248,81,73,0.08);">
        <div class="dash-card-top">
            <div class="dash-card-icon" style="background:rgba(248,81,73,0.12);color:#f85149;">
                <i class="fas fa-file-pdf"></i>
            </div>
            <div class="dash-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
        <div class="dash-card-num">06</div>
        <h4 class="dash-card-title">PDF Rapor Al</h4>
        <p class="dash-card-desc">Tüm sisteme ait istatistikleri ve raporları PDF formatında indirin.</p>
        <div class="dash-card-footer">
            <span>PDF İndir</span>
            <i class="fas fa-download"></i>
        </div>
    </a>

</div>

<style>
    /* Live badge */
    .dashboard-live-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(56,210,100,0.1);
        border: 1px solid rgba(86,211,100,0.25);
        border-radius: 100px;
        padding: 6px 14px;
        font-size: 0.78rem;
        font-weight: 600;
        color: #56d364;
    }
    .live-dot {
        width: 7px; height: 7px;
        background: #56d364;
        border-radius: 50%;
        animation: live-pulse 1.5s ease-in-out infinite;
    }
    @@keyframes live-pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(86,211,100,0.4); }
        50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(86,211,100,0); }
    }

    /* Welcome Banner */
    .welcome-banner {
        position: relative;
        background: linear-gradient(135deg, #161b22 0%, #0d1117 100%);
        border: 1px solid #21262d;
        border-radius: 16px;
        padding: 32px 36px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 20px;
        overflow: hidden;
    }
    .welcome-banner-glow {
        position: absolute;
        top: -60px; left: -60px;
        width: 220px; height: 220px;
        background: radial-gradient(circle, rgba(56,139,253,0.08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }
    .welcome-avatar {
        width: 56px; height: 56px; min-width: 56px;
        background: linear-gradient(135deg, #1f6feb, #388bfd);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: white;
        box-shadow: 0 8px 24px rgba(56,139,253,0.3);
    }
    .welcome-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #e6edf3;
        margin: 0 0 4px;
    }
    .welcome-title span { color: #58a6ff; }
    .welcome-sub { color: #8b949e; font-size: 0.875rem; margin: 0; }
    .welcome-icon-deco {
        margin-left: auto;
        font-size: 5rem;
        color: rgba(255,255,255,0.02);
        line-height: 1;
    }

    /* Dashboard Grid */
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    @@media (max-width: 1100px) { .dashboard-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 640px)  { .dashboard-grid { grid-template-columns: 1fr; } }

    /* Dash Card */
    .dash-card {
        display: block;
        text-decoration: none;
        background: #161b22;
        border: 1px solid #21262d;
        border-radius: 16px;
        padding: 24px;
        position: relative;
        overflow: hidden;
        transition: all 0.25s ease;
        cursor: pointer;
    }
    .dash-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--accent-bg);
        opacity: 0;
        transition: opacity 0.25s;
    }
    .dash-card::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
        opacity: 0;
        transition: opacity 0.25s;
    }
    .dash-card:hover {
        border-color: rgba(255,255,255,0.08);
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(0,0,0,0.4);
    }
    .dash-card:hover::before { opacity: 1; }
    .dash-card:hover::after  { opacity: 1; }
    .dash-card:hover .dash-card-arrow { opacity: 1; transform: translateX(3px); }

    .dash-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
        position: relative;
    }
    .dash-card-icon {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
        transition: transform 0.2s;
    }
    .dash-card:hover .dash-card-icon { transform: scale(1.08); }

    .dash-card-arrow {
        color: #6e7681;
        opacity: 0;
        transition: all 0.2s;
        font-size: 0.8rem;
        margin-top: 4px;
    }

    .dash-card-num {
        font-size: 3.5rem;
        font-weight: 900;
        color: rgba(255,255,255,0.025);
        line-height: 1;
        position: absolute;
        bottom: 20px; right: 20px;
        font-family: 'Inter', sans-serif;
        letter-spacing: -2px;
        user-select: none;
    }

    .dash-card-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e6edf3;
        margin: 0 0 8px;
        position: relative;
    }
    .dash-card-desc {
        font-size: 0.8rem;
        color: #6e7681;
        margin: 0 0 20px;
        line-height: 1.6;
        position: relative;
    }
    .dash-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: var(--accent-color);
        font-size: 0.8rem;
        font-weight: 600;
        border-top: 1px solid #21262d;
        padding-top: 14px;
        position: relative;
        transition: gap 0.2s;
    }
</style>
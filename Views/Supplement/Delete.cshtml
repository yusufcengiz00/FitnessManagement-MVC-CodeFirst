@model Project1.Models.Supplement

@{
    ViewData["Title"] = "Supplement Sil";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-danger">Supplement Silme Onayı</h2>
    <h3>Bu supplementi silmek istediğinizden emin misiniz?</h3>
    <hr />

    <div class="card col-md-6 p-3">
        <p><strong>Adı:</strong> @Model.SupplementAdi</p>
        <p><strong>Soyadı:</strong> @Model.SupplementFiyati</p>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="SupplementID" />
            <input type="hidden" asp-for="SalonID" />
            <button type="submit" class="btn btn-danger">Evet, Sil</button>
            <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
        </form>
    </div>
</div>
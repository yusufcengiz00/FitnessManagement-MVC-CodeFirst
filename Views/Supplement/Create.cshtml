@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model Project1.Models.Supplement

@{
    ViewData["Title"] = "Yeni Supplement Ekle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <div class="admin-nav-icon icon-green" style="width:38px;height:38px;border-radius:10px;font-size:1rem;">
                <i class="fa-solid fa-plus"></i>
            </div>
            Yeni Supplement Ekle
        </h1>
        <p class="page-subtitle">Stoğa yeni bir takviye ürünü ekleyin.</p>
    </div>
    <a asp-action="Index" class="btn" style="background:rgba(139,148,158,0.1);border:1px solid #30363d;color:#8b949e;border-radius:8px;font-size:0.85rem;padding:8px 16px;">
        <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
    </a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">

        <div class="mb-4">
            <label class="dark-form-label">Supplement Adı</label>
            <input asp-for="SupplementAdi" class="form-control dark-form-control" placeholder="Ürün adını girin..." />
        </div>

        <div class="mb-4">
            <label class="dark-form-label">Fiyatı</label>
            <input asp-for="SupplementFiyati" class="form-control dark-form-control" placeholder="Ürün fiyatını girin..." />
        </div>

        <div class="mb-4">
            <label class="dark-form-label">Bulunduğu Salon</label>
            <select asp-for="SalonID" class="form-control dark-form-control">
                <option value="">— Lütfen Bir Salon Seçin —</option>
                @if (ViewBag.Salonlar != null)
                {
                    foreach (var salon in ViewBag.Salonlar)
                    {
                        <option value="@salon.SalonID">@salon.SalonAdi</option>
                    }
                }
            </select>
        </div>

        <div class="d-flex gap-2 mt-4 pt-2" style="border-top:1px solid #21262d;">
            <button type="submit" class="btn" style="background:linear-gradient(135deg,#1a7f37,#2ea043);color:white;border:none;border-radius:8px;padding:10px 24px;font-weight:600;font-size:0.875rem;">
                <i class="fa-solid fa-floppy-disk me-2"></i>Kaydet
            </button>
            <a asp-action="Index" class="btn" style="background:rgba(139,148,158,0.1);border:1px solid #30363d;color:#8b949e;border-radius:8px;padding:10px 20px;font-size:0.875rem;">
                Vazgeç
            </a>
        </div>

    </form>
</div>
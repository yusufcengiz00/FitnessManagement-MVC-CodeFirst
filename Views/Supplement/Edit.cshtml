@model Project1.Models.Supplement

@{
    ViewData["Title"] = "Supplement Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Admin layoutunu bağladık
}

<h1>Supplement Güncelle</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="SupplementID" />
            <input type="hidden" asp-for="SalonID" />

            <div class="form-group mb-3">
                <label class="control-label">Supplement Adı</label>
                <input asp-for="SupplementAdi" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Fiyatı</label>
                <input asp-for="SupplementFiyati" class="form-control" />
            </div>

            <div class="form-group">
                <input type="submit" value="Kaydet" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>
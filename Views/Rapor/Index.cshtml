@{
    ViewData["Title"] = "Detaylı Raporlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1 class="mt-2 h3 fw-bold text-gray-800">Gelişmiş Tesis ve Üye Analiz Raporları</h1>
    </div>
    <hr class="mb-4" />

    <div class="row">
        <div class="col-xl-6 mb-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-primary text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="card-title mb-0 fw-semibold"><i class="fas fa-users me-2"></i> Üye Demografisi Raporu</h5>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span>Aktif Üyelerin Yaş Ortalaması:</span>
                        <span class="badge bg-primary rounded-pill fs-6 px-3">@ViewBag.YasOrtalamasi Yaş</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span>En Yaşlı Üye Yaşı:</span>
                        <span class="badge bg-dark rounded-pill fs-6 px-3">@ViewBag.EnYasliUye</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span>En Genç Üye Yaşı:</span>
                        <span class="badge bg-info text-dark rounded-pill fs-6 px-3 fw-bold">@ViewBag.EnGencUye</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-danger text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="card-title mb-0 fw-semibold"><i class="fas fa-capsules me-2"></i> Mağaza & Ürün Çeşitliliği</h5>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span>En Pahalı Ürün:</span>
                        <span class="fw-bold text-danger fs-6">@ViewBag.EnPahaliUrunAdi</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span>En Pahalı Ürünün Fiyatı:</span>
                        <span class="badge bg-danger rounded-pill fs-6 px-3">@ViewBag.EnPahaliUrunFiyat TL</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span>Toplam Ürün Çeşidi (Envanter):</span>
                        <span class="badge bg-dark rounded-pill fs-6 px-3">@ViewBag.ToplamUrunCesidi Çeşit</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-warning text-dark py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="card-title mb-0 fw-semibold"><i class="fas fa-chart-pie me-2"></i> Şubelere Göre Üye Dağılımı</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Salon Adı</th>
                                    <th class="text-end pe-3">Kayıtlı Üye Sayısı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.SalonUyeSayilari != null)
                                {
                                    foreach (var item in ViewBag.SalonUyeSayilari)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-medium">@item.SalonAdi</td>
                                            <td class="text-end pe-3">
                                                <span class="badge bg-warning text-dark rounded-pill px-3 fw-bold">@item.UyeSayisi Üye</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-success text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="card-title mb-0 fw-semibold"><i class="fas fa-dumbbell me-2"></i> Antrenör Sorumluluk Atamaları</h5>
                </div>
                <div class="card-body p-0" style="max-height: 250px; overflow-y: auto;">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="ps-3">Antrenör (Kullanıcı Adı)</th>
                                    <th class="ps-3">Sorumlu Olduğu Üye</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.AntrenorUyeListesi != null)
                                {
                                    foreach (var item in ViewBag.AntrenorUyeListesi)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-medium text-success">@item.AntrenorAdi</td>
                                            <td class="ps-3">@item.UyeAdi</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-info text-dark py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="card-title mb-0 fw-semibold"><i class="fas fa-map-marker-alt me-2"></i> Üye - Şube Eşleşmeleri</h5>
                </div>
                <div class="card-body p-0" style="max-height: 250px; overflow-y: auto;">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="ps-3">Üye Adı Soyadı</th>
                                    <th class="ps-3">Kayıtlı Olduğu Salon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.UyeSalonListesi != null)
                                {
                                    foreach (var item in ViewBag.UyeSalonListesi)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-medium">@item.UyeAdi</td>
                                            <td class="ps-3 text-muted">@item.SalonAdi</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-secondary text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="card-title mb-0 fw-semibold"><i class="fas fa-store me-2"></i> Şube Supplement Envanter Dağılımı</h5>
                </div>
                <div class="card-body p-0" style="max-height: 250px; overflow-y: auto;">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="ps-3">Ürün Adı</th>
                                    <th class="ps-3">Satışta Olduğu Şube</th>
                                    <th class="text-end pe-3">Fiyat</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.SupplementSalonListesi != null)
                                {
                                    foreach (var item in ViewBag.SupplementSalonListesi)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-medium">@item.SupplementAdi</td>
                                            <td class="ps-3">@item.SalonAdi</td>
                                            <td class="text-end pe-3 fw-bold text-secondary">@item.Fiyat TL</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<br /><br />
<div class="d-flex align-items-center mb-4">
    <a asp-controller="Rapor" asp-action="ExportToPdf" class="btn btn-danger">
        <i class="fa fa-file-pdf"></i> PDF Olarak İndir
    </a>
    <a asp-controller="Rapor" asp-action="ExportToExcel" class="btn btn-success">
        <i class="fa fa-file-excel"></i> Excel Olarak İndir
    </a>
</div>

@model Project1.Models.Salon

@{
    ViewData["Title"] = "Salon Sil";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <div class="admin-nav-icon" style="width:38px;height:38px;border-radius:10px;font-size:1rem;background:rgba(248,81,73,0.15);color:#f85149;">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            Salon Silme Onayı
        </h1>
        <p class="page-subtitle">Bu işlem geri alınamaz. Lütfen dikkatli olun.</p>
    </div>
</div>

<div class="delete-card">
    <div class="mb-4 pb-3" style="border-bottom:1px solid #21262d;">
        <p style="color:#8b949e;font-size:0.875rem;margin:0;">
            <i class="fas fa-info-circle me-2 text-warning"></i>
            Aşağıdaki salonu kalıcı olarak silmek istediğinizden emin misiniz?
        </p>
    </div>

    <div class="delete-info-row">
        <span class="delete-info-label"><i class="fas fa-building me-2"></i>Salon Adı</span>
        <span class="delete-info-value">@Model.SalonAdi</span>
    </div>
    <div class="delete-info-row">
        <span class="delete-info-label"><i class="fas fa-location-dot me-2"></i>Salon Adresi</span>
        <span class="delete-info-value">@Model.SalonAdres</span>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="SalonID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn" style="background:linear-gradient(135deg,#b91c1c,#dc2626);color:white;border:none;border-radius:8px;padding:10px 24px;font-weight:600;font-size:0.875rem;">
                <i class="fa-solid fa-trash me-2"></i>Evet, Sil
            </button>
            <a asp-action="Index" class="btn" style="background:rgba(139,148,158,0.1);border:1px solid #30363d;color:#8b949e;border-radius:8px;padding:10px 20px;font-size:0.875rem;">
                Vazgeç
            </a>
        </div>
    </form>
</div>
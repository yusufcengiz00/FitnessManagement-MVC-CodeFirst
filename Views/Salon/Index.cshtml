@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Salon Listesi";
}

@model IEnumerable<Project1.Models.Salon>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">
                <i class="fa-solid fa-map-location-dot text-info me-2" style="color:ghostwhite"></i>Salon / Şube Listesi
            </h2>
            <small class="text-muted" style="color:ghostwhite">Aktif antrenman salonlarını, konum bilgilerini ve şubeleri yönetin.</small>
        </div>
        <a asp-action="Create" class="btn btn-info text-white btn-lg shadow-sm rounded-pill px-4" style="background-color: #0dcaf0; border: none;">
            <i class="fa-solid fa-house-chimney-medical me-2"></i>Yeni Salon Ekle
        </a>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-controller="Salon" asp-action="ExportToPdf" class="btn btn-danger">
            <i class="fa fa-file-pdf"></i> PDF Olarak İndir
        </a>
        <a asp-controller="Salon" asp-action="ExportToExcel" class="btn btn-success">
            <i class="fa fa-file-excel"></i> Excel Olarak İndir
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-3 bg-light rounded-3">
            <form asp-action="Index" method="get">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md-5 col-lg-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </span>
                            <input type="text" name="searchString" class="form-control border-start-0 ps-0"
                                   placeholder="Salon adı ara..." value="@ViewBag.CurrentFilter" />

                            <button class="btn btn-info text-white px-4" type="submit" style="background-color: #0dcaf0; border: none;">Ara</button>

                            @if (!String.IsNullOrEmpty(ViewBag.CurrentFilter))
                            {
                                <a asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-xmark"></i></a>
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark bg-gradient text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="ps-4 py-3" style="width: 300px;">Salon Adı</th>
                        <th class="py-3">Salon Adresi</th>
                        <th class="pe-4 py-3 text-end" style="width: 250px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var salon in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3 fw-semibold text-dark">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-info-subtle text-info rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; min-width: 40px;">
                                            <i class="fa-solid fa-building-shield" style="font-size: 0.95rem;"></i>
                                        </div>
                                        <span>@salon.SalonAdi</span>
                                    </div>
                                </td>
                                <td class="text-secondary py-3">
                                    <i class="fa-solid fa-location-dot text-danger opacity-75 me-2"></i>@salon.SalonAdres
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <div class="btn-group gap-1">
                                        <a asp-action="Edit" asp-route-id="@salon.SalonID" class="btn btn-outline-warning btn-sm rounded-2 px-3">
                                            <i class="fa-solid fa-pen-to-square me-1"></i> Güncelle
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@salon.SalonID" class="btn btn-outline-danger btn-sm rounded-2 px-3">
                                            <i class="fa-solid fa-trash me-1"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-map-pin display-6 d-block mb-3 text-secondary"></i>
                                Aradığınız kriterlere uygun salon bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(13, 202, 240, 0.02);
        transition: background-color 0.2s ease-in-out;
    }

    .form-control:focus {
        box-shadow: none;
        border-color: #dee2e6;
    }

    .input-group:focus-within {
        box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.15);
        border-radius: 0.375rem;
    }

    .bg-info-subtle {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }

    .text-info {
        color: #0dcaf0 !important;
    }
</style>
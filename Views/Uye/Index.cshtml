@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Üye Listesi";
}

@model IEnumerable<Project1.Models.Uye>

<div class="page-header">
    <div>
        <h1 class="page-title">
            <div class="admin-nav-icon icon-blue" style="width:38px;height:38px;border-radius:10px;font-size:1rem;">
                <i class="fa-solid fa-users"></i>
            </div>
            Fitness Üye Listesi
        </h1>
        <p class="page-subtitle">Kayıtlı üyeleri yönetin, arayın ve güncelleyin.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <a asp-controller="Uye" asp-action="ExportToPdf" class="btn export-btn-pdf">
            <i class="fa fa-file-pdf me-1"></i>PDF
        </a>
        <a asp-controller="Uye" asp-action="ExportToExcel" class="btn export-btn-excel">
            <i class="fa fa-file-excel me-1"></i>Excel
        </a>
        <a asp-action="Create" class="btn" style="background:linear-gradient(135deg,#1f6feb,#388bfd);color:white;border:none;border-radius:8px;padding:9px 18px;font-weight:600;font-size:0.875rem;">
            <i class="fa-solid fa-user-plus me-2"></i>Yeni Üye Ekle
        </a>
    </div>
</div>

<div class="dark-search-card">
    <form asp-action="Index" method="get">
        <div class="d-flex align-items-center gap-2">
            <div class="input-group dark-input-group" style="max-width:420px;">
                <span class="input-group-text">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" name="searchString" class="form-control"
                       placeholder="Üye adı veya soyadı ara..." value="@ViewBag.CurrentFilter" />
                <button class="btn" type="submit" style="background:rgba(56,139,253,0.15);border:1px solid rgba(56,139,253,0.3);color:#58a6ff;font-size:0.85rem;padding:0 16px;">
                    Ara
                </button>
                @if (!String.IsNullOrEmpty(ViewBag.CurrentFilter))
                {
                    <a asp-action="Index" class="btn" style="background:rgba(139,148,158,0.1);border:1px solid #30363d;color:#8b949e;">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                }
            </div>
        </div>
    </form>
</div>

<div class="dark-card overflow-hidden">
    <div class="table-responsive">
        <table class="table dark-table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Üye Bilgisi</th>
                    <th>Soyadı</th>
                    <th class="text-center">Yaş</th>
                    <th class="text-center">Kayıtlı Salon</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var uye in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-dark icon-blue" style="background:rgba(31,111,235,0.15);">
                                        @uye.UyeAdi.Substring(0, 1).ToUpper()
                                    </div>
                                    <span style="color:#e6edf3;font-weight:600;">@uye.UyeAdi</span>
                                </div>
                            </td>
                            <td style="color:#8b949e;">@uye.UyeSoyadi</td>
                            <td class="text-center">
                                <span class="badge-dark-age">@uye.Yas Yaş</span>
                            </td>
                            <td class="text-center">
                                <span class="badge-dark-salon">
                                    <i class="fas fa-building me-1" style="font-size:0.7rem;"></i>
                                    @uye.Salonlar?.SalonAdi
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@uye.UyeID" class="btn btn-dark-edit">
                                        <i class="fa-solid fa-pen-to-square me-1"></i>Güncelle
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@uye.UyeID" class="btn btn-dark-delete">
                                        <i class="fa-solid fa-trash me-1"></i>Sil
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="fa-solid fa-user-slash fa-2x d-block mb-3" style="color:#30363d;"></i>
                            <span style="color:#6e7681;font-size:0.875rem;">Aradığınız kriterlere uygun üye bulunamadı.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
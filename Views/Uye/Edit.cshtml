@model Project1.Models.Uye

@{
    ViewData["Title"] = "Üye Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Admin layoutunu bağladık
}

<h1>Üye Güncelle</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="UyeID" />
            <input type="hidden" asp-for="SalonID" />

            <div class="form-group mb-3">
                <label class="control-label">Üye Adı</label>
                <input asp-for="UyeAdi" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Soyadı</label>
                <input asp-for="UyeSoyadi" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Yaş</label>
                <input asp-for="Yas" class="form-control" />
            </div>

            <div class="form-group">
                <input type="submit" value="Kaydet" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Fitness Center — Sağlıklı yaşam ve profesyonel antrenman için doğru adres." />
    <title>@ViewData["Title"] - Fitness Center</title>
    <link rel="icon" type="image/x-icon" href="~/userstemplate/assets/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Bebas+Neue&display=swap" rel="stylesheet" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* ============================================
           RESET & BASE
        ============================================ */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg-deep:    #050811;
            --bg-dark:    #0a0f1e;
            --bg-card:    #0d1529;
            --bg-raised:  #111827;
            --border:     rgba(255,255,255,0.06);
            --border-glow:rgba(56,189,248,0.25);
            --text-primary: #f0f6ff;
            --text-sec:   #94a3b8;
            --text-muted: #475569;
            --accent:     #38bdf8;
            --accent2:    #6366f1;
            --accent3:    #10b981;
            --accent-glow:rgba(56,189,248,0.15);
        }

        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* ============================================
           ANIMATED BACKGROUND GRID
        ============================================ */
        .bg-grid {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-image:
                linear-gradient(rgba(56,189,248,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(56,189,248,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }

        .bg-orb-1 {
            position: fixed;
            top: -200px; left: -200px;
            width: 700px; height: 700px;
            background: radial-gradient(circle, rgba(56,189,248,0.06) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            animation: float1 8s ease-in-out infinite;
        }
        .bg-orb-2 {
            position: fixed;
            bottom: -100px; right: -100px;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(99,102,241,0.07) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            animation: float2 10s ease-in-out infinite;
        }
        @keyframes float1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,30px)} }
        @keyframes float2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-30px,-20px)} }

        /* ============================================
           NAVBAR
        ============================================ */
        #mainNav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 0;
            transition: all 0.3s ease;
        }

        .navbar-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1200px;
            margin: 0 auto;
            padding: 18px 24px;
            transition: padding 0.3s;
        }

        #mainNav.scrolled {
            background: rgba(5, 8, 17, 0.9) !important;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 4px 30px rgba(0,0,0,0.4);
        }
        #mainNav.scrolled .navbar-inner { padding: 12px 24px; }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .nav-brand-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; color: white;
            box-shadow: 0 0 20px rgba(56,189,248,0.3);
        }
        .nav-brand-text {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }
        .nav-brand-text span { color: var(--accent); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 8px;
            list-style: none;
        }
        .nav-links a {
            color: var(--text-sec);
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            padding: 7px 14px;
            border-radius: 8px;
            transition: all 0.2s;
        }
        .nav-links a:hover {
            color: var(--text-primary);
            background: rgba(255,255,255,0.05);
        }
        .nav-links .nav-admin {
            background: rgba(56,189,248,0.1);
            border: 1px solid rgba(56,189,248,0.25);
            color: var(--accent);
            font-weight: 600;
        }
        .nav-links .nav-admin:hover {
            background: rgba(56,189,248,0.2);
            color: var(--accent);
        }

        .nav-toggler {
            display: none;
            background: none;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px 10px;
            color: var(--text-sec);
            cursor: pointer;
            font-size: 1rem;
        }

        @media (max-width: 768px) {
            .nav-toggler { display: block; }
            .nav-links {
                display: none;
                position: absolute;
                top: 100%; left: 0; right: 0;
                background: rgba(10,15,30,0.97);
                backdrop-filter: blur(20px);
                flex-direction: column;
                padding: 16px;
                border-bottom: 1px solid var(--border);
                gap: 4px;
            }
            .nav-links.open { display: flex; }
            .nav-links a { width: 100%; text-align: center; padding: 10px; }
        }

        /* ============================================
           HERO SECTION
        ============================================ */
        .hero-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            z-index: 1;
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('/userstemplate/assets/img/bg-masthead.jpg');
            background-size: cover;
            background-position: center;
            filter: brightness(0.15) saturate(0.5);
            z-index: 0;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                135deg,
                rgba(5,8,17,0.7) 0%,
                rgba(56,189,248,0.05) 50%,
                rgba(5,8,17,0.8) 100%
            );
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            max-width: 850px;
            padding: 0 24px;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(56,189,248,0.1);
            border: 1px solid rgba(56,189,248,0.25);
            border-radius: 100px;
            padding: 6px 16px;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--accent);
            letter-spacing: 0.5px;
            margin-bottom: 28px;
            backdrop-filter: blur(10px);
        }
        .hero-badge-dot {
            width: 6px; height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: pulse-dot 2s ease-in-out infinite;
        }
        @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.7)} }

        .hero-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(3.5rem, 9vw, 7.5rem);
            line-height: 0.95;
            letter-spacing: 2px;
            margin-bottom: 24px;
            color: var(--text-primary);
        }
        .hero-title .accent-word {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: block;
        }

        .hero-subtitle {
            font-size: 1.1rem;
            color: var(--text-sec);
            max-width: 560px;
            margin: 0 auto 40px;
            line-height: 1.7;
            font-weight: 400;
        }

        .hero-cta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            flex-wrap: wrap;
        }

        .btn-primary-glow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 32px;
            background: linear-gradient(135deg, var(--accent), #0ea5e9);
            color: #050811;
            font-weight: 700;
            font-size: 0.9rem;
            border: none;
            border-radius: 12px;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 0 30px rgba(56,189,248,0.3);
            letter-spacing: 0.3px;
        }
        .btn-primary-glow:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 50px rgba(56,189,248,0.5);
            color: #050811;
        }

        .btn-outline-glass {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 28px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.12);
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.9rem;
            border-radius: 12px;
            text-decoration: none;
            transition: all 0.3s;
            backdrop-filter: blur(10px);
        }
        .btn-outline-glass:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.2);
            color: var(--text-primary);
            transform: translateY(-2px);
        }

        .hero-stats {
            position: absolute;
            bottom: 48px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            display: flex;
            gap: 48px;
            align-items: center;
        }
        .hero-stat {
            text-align: center;
        }
        .hero-stat-num {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-primary);
            line-height: 1;
        }
        .hero-stat-num span { color: var(--accent); }
        .hero-stat-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 4px;
        }
        .hero-stat-divider {
            width: 1px;
            height: 40px;
            background: var(--border);
        }

        .hero-scroll {
            position: absolute;
            bottom: 32px;
            right: 40px;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            color: var(--text-muted);
            font-size: 0.7rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .hero-scroll-line {
            width: 1px;
            height: 40px;
            background: linear-gradient(to bottom, var(--accent), transparent);
            animation: scroll-line 1.5s ease-in-out infinite;
        }
        @keyframes scroll-line { 0%{opacity:0;transform:scaleY(0) translateY(-100%)} 50%{opacity:1} 100%{opacity:0;transform:scaleY(1) translateY(0)} }

        /* ============================================
           FEATURES STRIP
        ============================================ */
        .features-strip {
            position: relative;
            z-index: 1;
            padding: 0;
            background: var(--bg-card);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .features-strip-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            divide: 1;
        }
        .feature-strip-item {
            padding: 28px 32px;
            display: flex;
            align-items: center;
            gap: 16px;
            border-right: 1px solid var(--border);
            transition: background 0.2s;
        }
        .feature-strip-item:last-child { border-right: none; }
        .feature-strip-item:hover { background: rgba(56,189,248,0.03); }
        .feature-strip-icon {
            width: 44px; height: 44px; min-width: 44px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
        }
        .feature-strip-text h6 {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 2px;
        }
        .feature-strip-text p {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin: 0;
        }

        @media (max-width: 768px) {
            .features-strip-inner { grid-template-columns: repeat(2, 1fr); }
            .feature-strip-item:nth-child(2) { border-right: none; }
            .feature-strip-item:nth-child(3) { border-top: 1px solid var(--border); }
            .feature-strip-item:nth-child(4) { border-top: 1px solid var(--border); border-right: none; }
        }
        @media (max-width: 480px) {
            .features-strip-inner { grid-template-columns: 1fr; }
            .feature-strip-item { border-right: none; border-top: 1px solid var(--border); }
            .feature-strip-item:first-child { border-top: none; }
        }

        /* ============================================
           ABOUT SECTION
        ============================================ */
        .about-section {
            position: relative;
            z-index: 1;
            padding: 120px 0;
            background: var(--bg-deep);
        }

        .section-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 16px;
        }
        .section-label::before {
            content: '';
            display: block;
            width: 24px; height: 1px;
            background: var(--accent);
        }

        .section-title {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800;
            color: var(--text-primary);
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 20px;
        }
        .section-title .highlight {
            color: var(--accent);
        }

        .section-desc {
            font-size: 1rem;
            color: var(--text-sec);
            line-height: 1.8;
            max-width: 480px;
        }

        .about-image-wrapper {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
        }
        .about-image-wrapper img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-radius: 20px;
            display: block;
        }
        .about-image-wrapper::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(56,189,248,0.1), transparent);
            border-radius: 20px;
            z-index: 1;
            pointer-events: none;
        }
        .about-image-border {
            position: absolute;
            inset: 0;
            border: 1px solid rgba(56,189,248,0.2);
            border-radius: 20px;
            z-index: 2;
            pointer-events: none;
        }
        .about-floating-badge {
            position: absolute;
            bottom: -16px;
            left: -16px;
            z-index: 3;
            background: var(--bg-card);
            border: 1px solid var(--border-glow);
            border-radius: 14px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        .about-floating-icon {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            color: white;
        }
        .about-floating-text strong {
            display: block;
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--text-primary);
            line-height: 1;
        }
        .about-floating-text span {
            font-size: 0.72rem;
            color: var(--text-muted);
        }

        .about-list {
            list-style: none;
            margin: 28px 0;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .about-list li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 0.9rem;
            color: var(--text-sec);
            line-height: 1.5;
        }
        .about-list-check {
            width: 20px; height: 20px; min-width: 20px;
            background: rgba(16,185,129,0.15);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.65rem;
            color: var(--accent3);
            margin-top: 1px;
        }

        /* ============================================
           SERVICES SECTION
        ============================================ */
        .services-section {
            position: relative;
            z-index: 1;
            padding: 120px 0;
            background: var(--bg-dark);
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 60px;
        }
        @media (max-width: 992px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 576px) { .services-grid { grid-template-columns: 1fr; } }

        .service-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 32px 28px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            cursor: default;
        }
        .service-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent)), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .service-card:hover {
            border-color: rgba(255,255,255,0.1);
            transform: translateY(-4px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        }
        .service-card:hover::before { opacity: 1; }

        .service-card-icon {
            width: 52px; height: 52px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            margin-bottom: 20px;
        }
        .service-card h4 {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 10px;
        }
        .service-card p {
            font-size: 0.85rem;
            color: var(--text-muted);
            line-height: 1.7;
            margin: 0;
        }
        .service-card-number {
            position: absolute;
            top: 24px; right: 24px;
            font-size: 3.5rem;
            font-weight: 900;
            color: rgba(255,255,255,0.03);
            line-height: 1;
            font-family: 'Bebas Neue', sans-serif;
        }

        /* ============================================
           PROMO BANNER
        ============================================ */
        .promo-section {
            position: relative;
            z-index: 1;
            padding: 80px 0;
            background: var(--bg-deep);
            overflow: hidden;
        }
        .promo-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            position: relative;
        }
        .promo-card {
            background: var(--bg-card);
            border: 1px solid rgba(56,189,248,0.15);
            border-radius: 24px;
            padding: 60px;
            display: flex;
            align-items: center;
            gap: 48px;
            position: relative;
            overflow: hidden;
        }
        .promo-card::before {
            content: '';
            position: absolute;
            top: -100px; right: -100px;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(56,189,248,0.05) 0%, transparent 70%);
            border-radius: 50%;
        }
        .promo-card-img {
            flex-shrink: 0;
            width: 260px;
            height: 200px;
            border-radius: 16px;
            overflow: hidden;
        }
        .promo-card-img img {
            width: 100%; height: 100%;
            object-fit: cover;
            filter: brightness(0.85) saturate(0.9);
        }
        .promo-card-content { flex: 1; }
        .promo-card-content h2 {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 12px;
            line-height: 1.1;
        }
        .promo-card-content p {
            font-size: 0.9rem;
            color: var(--text-sec);
            margin-bottom: 28px;
            line-height: 1.7;
        }

        @media (max-width: 768px) {
            .promo-card { flex-direction: column; padding: 32px; }
            .promo-card-img { width: 100%; height: 200px; }
        }

        /* ============================================
           CONTACT SECTION
        ============================================ */
        .contact-section {
            position: relative;
            z-index: 1;
            padding: 120px 0;
            background: var(--bg-dark);
        }

        .contact-cards {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-top: 60px;
        }
        @media (max-width: 576px) { .contact-cards { grid-template-columns: 1fr; } }

        .contact-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 36px 32px;
            display: flex;
            align-items: flex-start;
            gap: 20px;
            transition: all 0.3s;
        }
        .contact-card:hover {
            border-color: rgba(255,255,255,0.1);
            transform: translateY(-3px);
            box-shadow: 0 16px 48px rgba(0,0,0,0.3);
        }
        .contact-card-icon {
            width: 48px; height: 48px; min-width: 48px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
        }
        .contact-card h5 {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin: 0 0 6px;
        }
        .contact-card p {
            font-size: 0.95rem;
            color: var(--text-primary);
            margin: 0;
            font-weight: 500;
        }
        .contact-card a {
            color: var(--accent);
            text-decoration: none;
        }
        .contact-card a:hover { text-decoration: underline; }

        /* ============================================
           FOOTER
        ============================================ */
        .site-footer {
            position: relative;
            z-index: 1;
            background: var(--bg-deep);
            border-top: 1px solid var(--border);
            padding: 40px 0;
        }
        .footer-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }
        .footer-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .footer-brand-icon {
            width: 32px; height: 32px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; color: white;
        }
        .footer-brand-name {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text-primary);
        }
        .footer-brand-name span { color: var(--accent); }
        .footer-copy {
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        .footer-links {
            display: flex;
            gap: 20px;
        }
        .footer-links a {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s;
        }
        .footer-links a:hover { color: var(--accent); }

        /* ============================================
           CONTAINER UTILITY
        ============================================ */
        .section-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* ============================================
           SCROLL REVEAL ANIMATION
        ============================================ */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .reveal-delay-1 { transition-delay: 0.1s; }
        .reveal-delay-2 { transition-delay: 0.2s; }
        .reveal-delay-3 { transition-delay: 0.3s; }
        .reveal-delay-4 { transition-delay: 0.4s; }
        .reveal-delay-5 { transition-delay: 0.5s; }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div class="bg-grid"></div>
    <div class="bg-orb-1"></div>
    <div class="bg-orb-2"></div>

    <!-- ============================
         NAVBAR
    ============================ -->
    <nav id="mainNav">
        <div class="navbar-inner">
            <a class="nav-brand" href="#hero">
                <div class="nav-brand-icon"><i class="fas fa-dumbbell"></i></div>
                <span class="nav-brand-text">Fitness<span>Center</span></span>
            </a>

            <button class="nav-toggler" onclick="document.getElementById('navLinks').classList.toggle('open')">
                <i class="fas fa-bars"></i>
            </button>

            <ul class="nav-links" id="navLinks">
                <li><a href="#about">Hakkımızda</a></li>
                <li><a href="#services">Hizmetler</a></li>
                <li><a href="#contact">İletişim</a></li>
                <li><a class="nav-admin" asp-controller="Admin" asp-action="AdminIndex">
                    <i class="fas fa-lock me-1"></i>Admin Panel
                </a></li>
            </ul>
        </div>
    </nav>

    <!-- ============================
         HERO
    ============================ -->
    <section class="hero-section" id="hero">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>

        <div class="hero-content">
            <div class="hero-badge">
                <div class="hero-badge-dot"></div>
                İstanbul'un En İyi Fitness Merkezi
            </div>

            <h1 class="hero-title">
                Gücünü
                <span class="accent-word">Keşfet</span>
            </h1>

            <p class="hero-subtitle">
                Sağlıklı bir yaşam ve hayalindeki vücut için en doğru adrestesin.
                Uzman antrenörler, modern ekipmanlar ve kişiselleştirilmiş programlar seni bekliyor.
            </p>

            <div class="hero-cta">
                <a href="#about" class="btn-primary-glow">
                    <i class="fas fa-play"></i>
                    Başlayalım
                </a>
                <a href="#services" class="btn-outline-glass">
                    Hizmetlerimiz
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="hero-stats">
            <div class="hero-stat">
                <div class="hero-stat-num">500<span>+</span></div>
                <div class="hero-stat-label">Aktif Üye</div>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <div class="hero-stat-num">15<span>+</span></div>
                <div class="hero-stat-label">Uzman Antrenör</div>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <div class="hero-stat-num">5<span></span></div>
                <div class="hero-stat-label">Şube</div>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <div class="hero-stat-num">8<span>yıl</span></div>
                <div class="hero-stat-label">Deneyim</div>
            </div>
        </div>

        <div class="hero-scroll">
            <div class="hero-scroll-line"></div>
            Scroll
        </div>
    </section>

    <!-- ============================
         FEATURES STRIP
    ============================ -->
    <div class="features-strip">
        <div class="features-strip-inner">
            <div class="feature-strip-item">
                <div class="feature-strip-icon" style="background:rgba(56,189,248,0.1);">
                    <i class="fas fa-dumbbell" style="color:#38bdf8;font-size:1.1rem;"></i>
                </div>
                <div class="feature-strip-text">
                    <h6>Modern Ekipmanlar</h6>
                    <p>Son teknoloji fitness aletleri</p>
                </div>
            </div>
            <div class="feature-strip-item">
                <div class="feature-strip-icon" style="background:rgba(99,102,241,0.1);">
                    <i class="fas fa-user-tie" style="color:#818cf8;font-size:1.1rem;"></i>
                </div>
                <div class="feature-strip-text">
                    <h6>Uzman Antrenörler</h6>
                    <p>Sertifikalı profesyonel kadro</p>
                </div>
            </div>
            <div class="feature-strip-item">
                <div class="feature-strip-icon" style="background:rgba(16,185,129,0.1);">
                    <i class="fas fa-capsules" style="color:#10b981;font-size:1.1rem;"></i>
                </div>
                <div class="feature-strip-text">
                    <h6>Supplement Mağaza</h6>
                    <p>Kaliteli takviye ürünleri</p>
                </div>
            </div>
            <div class="feature-strip-item">
                <div class="feature-strip-icon" style="background:rgba(245,158,11,0.1);">
                    <i class="fas fa-clock" style="color:#f59e0b;font-size:1.1rem;"></i>
                </div>
                <div class="feature-strip-text">
                    <h6>7/24 Açık</h6>
                    <p>Dilediğin zaman antrenman</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================
         ABOUT
    ============================ -->
    <section class="about-section" id="about">
        <div class="section-container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 reveal">
                    <div class="about-image-wrapper">
                        <img src="~/userstemplate/assets/img/ipad.jpg" alt="Fitness Center" />
                        <div class="about-image-border"></div>
                        <div class="about-floating-badge">
                            <div class="about-floating-icon">
                                <i class="fas fa-trophy"></i>
                            </div>
                            <div class="about-floating-text">
                                <strong>#1</strong>
                                <span>İstanbul'un En İyisi</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 reveal reveal-delay-2">
                    <div class="section-label">
                        Hakkımızda
                    </div>
                    <h2 class="section-title">
                        Modern Spor <span class="highlight">Alanları</span>
                    </h2>
                    <p class="section-desc">
                        Son teknoloji ekipmanlarımız, uzman antrenör kadromuz ve geniş salonlarımızla hedeflerinize ulaşmanız için her şeyi hazırladık.
                    </p>
                    <ul class="about-list">
                        <li>
                            <div class="about-list-check"><i class="fas fa-check"></i></div>
                            Kişiye özel antrenman ve beslenme programları
                        </li>
                        <li>
                            <div class="about-list-check"><i class="fas fa-check"></i></div>
                            Deneyimli ve sertifikalı antrenör kadrosu
                        </li>
                        <li>
                            <div class="about-list-check"><i class="fas fa-check"></i></div>
                            İstanbul genelinde 5 modern şube
                        </li>
                        <li>
                            <div class="about-list-check"><i class="fas fa-check"></i></div>
                            Yüksek kalite supplement ürün mağazası
                        </li>
                    </ul>
                    <a href="#services" class="btn-primary-glow" style="display:inline-flex;">
                        Hizmetlerimizi Keşfet
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================
         SERVICES
    ============================ -->
    <section class="services-section" id="services">
        <div class="section-container">
            <div class="text-center reveal">
                <div class="section-label" style="justify-content:center;">Hizmetlerimiz</div>
                <h2 class="section-title">Sana Özel <span class="highlight">Çözümler</span></h2>
                <p style="color:var(--text-sec);font-size:0.95rem;max-width:500px;margin:0 auto;">
                    Fitness hedeflerine ulaşmak için ihtiyacın olan her şey tek bir çatı altında.
                </p>
            </div>

            <div class="services-grid">
                <div class="service-card reveal reveal-delay-1" style="--card-accent:#38bdf8;">
                    <div class="service-card-number">01</div>
                    <div class="service-card-icon" style="background:rgba(56,189,248,0.1);">
                        <i class="fas fa-person-running" style="color:#38bdf8;"></i>
                    </div>
                    <h4>Kişisel Antrenman</h4>
                    <p>Birebir antrenör eşliğinde, sana özel tasarlanmış antrenman programları ile hedeflerine hızlıca ulaş.</p>
                </div>
                <div class="service-card reveal reveal-delay-2" style="--card-accent:#818cf8;">
                    <div class="service-card-number">02</div>
                    <div class="service-card-icon" style="background:rgba(99,102,241,0.1);">
                        <i class="fas fa-users" style="color:#818cf8;"></i>
                    </div>
                    <h4>Grup Dersleri</h4>
                    <p>Yoga, pilates, HIIT ve daha fazlası — sosyal ve motive edici grup ortamında antrenman keyfi.</p>
                </div>
                <div class="service-card reveal reveal-delay-3" style="--card-accent:#10b981;">
                    <div class="service-card-number">03</div>
                    <div class="service-card-icon" style="background:rgba(16,185,129,0.1);">
                        <i class="fas fa-apple-whole" style="color:#10b981;"></i>
                    </div>
                    <h4>Beslenme Danışmanlığı</h4>
                    <p>Uzman diyetisyenlerden kişiselleştirilmiş beslenme planı ve supplement önerileri al.</p>
                </div>
                <div class="service-card reveal reveal-delay-4" style="--card-accent:#f59e0b;">
                    <div class="service-card-number">04</div>
                    <div class="service-card-icon" style="background:rgba(245,158,11,0.1);">
                        <i class="fas fa-dumbbell" style="color:#f59e0b;"></i>
                    </div>
                    <h4>Güç & Kondisyon</h4>
                    <p>Vücut geliştirme, güç antrenmanı ve kondisyon programlarıyla sınırlarını zorla.</p>
                </div>
                <div class="service-card reveal reveal-delay-5" style="--card-accent:#f43f5e;">
                    <div class="service-card-number">05</div>
                    <div class="service-card-icon" style="background:rgba(244,63,94,0.1);">
                        <i class="fas fa-spa" style="color:#f43f5e;"></i>
                    </div>
                    <h4>Yenileme & Recovery</h4>
                    <p>Sauna, masaj ve recovery ekipmanları ile kaslarını dinlendir ve yenile.</p>
                </div>
                <div class="service-card reveal reveal-delay-2" style="--card-accent:#06b6d4;">
                    <div class="service-card-number">06</div>
                    <div class="service-card-icon" style="background:rgba(6,182,212,0.1);">
                        <i class="fas fa-capsules" style="color:#06b6d4;"></i>
                    </div>
                    <h4>Supplement Mağaza</h4>
                    <p>Protein tozu, kreatin, vitamin ve daha fazlası — güvenilir markaların en kaliteli ürünleri.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Extra page body (for pages using this layout) -->
    @RenderBody()

    <!-- ============================
         PROMO BANNER
    ============================ -->
    <section class="promo-section">
        <div class="promo-inner">
            <div class="promo-card reveal">
                <div class="promo-card-img">
                    <img src="~/userstemplate/assets/img/bg-masthead.jpg" alt="Hedefine Odaklan" />
                </div>
                <div class="promo-card-content">
                    <h2>Hedefine<br /><span style="color:var(--accent);">Odaklan</span></h2>
                    <p>
                        Kişiye özel antrenman programları ve supplement destek planlamalarıyla gelişimini şansa bırakma.
                        Uzman antrenörlerimiz her adımında yanında.
                    </p>
                    <a href="#contact" class="btn-primary-glow" style="display:inline-flex;">
                        Üye Ol
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================
         CONTACT
    ============================ -->
    <section class="contact-section" id="contact">
        <div class="section-container">
            <div class="text-center reveal">
                <div class="section-label" style="justify-content:center;">İletişim</div>
                <h2 class="section-title">Bize <span class="highlight">Ulaşın</span></h2>
                <p style="color:var(--text-sec);font-size:0.95rem;max-width:500px;margin:0 auto;">
                    Sorularınız için her zaman buradayız.
                </p>
            </div>

            <div class="contact-cards">
                <div class="contact-card reveal reveal-delay-1">
                    <div class="contact-card-icon" style="background:rgba(56,189,248,0.1);">
                        <i class="fas fa-location-dot" style="color:#38bdf8;"></i>
                    </div>
                    <div>
                        <h5>Adres</h5>
                        <p>Merkez Şubesi, İstanbul, Türkiye</p>
                    </div>
                </div>
                <div class="contact-card reveal reveal-delay-2">
                    <div class="contact-card-icon" style="background:rgba(16,185,129,0.1);">
                        <i class="fas fa-envelope" style="color:#10b981;"></i>
                    </div>
                    <div>
                        <h5>E-Posta</h5>
                        <p><a href="mailto:info@fitnesscenter.com">info@fitnesscenter.com</a></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================
         FOOTER
    ============================ -->
    <footer class="site-footer">
        <div class="footer-inner">
            <a class="footer-brand" href="#hero">
                <div class="footer-brand-icon"><i class="fas fa-dumbbell"></i></div>
                <span class="footer-brand-name">Fitness<span>Center</span></span>
            </a>
            <div class="footer-copy">Copyright &copy; Fitness Center 2026. Tüm hakları saklıdır.</div>
            <div class="footer-links">
                <a href="#about">Hakkımızda</a>
                <a href="#services">Hizmetler</a>
                <a href="#contact">İletişim</a>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Navbar scroll effect
        const nav = document.getElementById('mainNav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 40);
        });

        // Scroll reveal
        const revealEls = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

        revealEls.forEach(el => observer.observe(el));
    </script>
</body>
</html>
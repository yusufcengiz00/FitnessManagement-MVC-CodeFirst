<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Fitness Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/admintemplate/css/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="sb-nav-fixed" style="background-color: #fff; color: black;">

    <nav class="sb-topnav navbar navbar-expand navbar-dark" style="background-color: #1e2533; border-bottom: 1px solid #2d3748;">
        <a class="navbar-brand ps-3 fw-bold text-uppercase" asp-controller="Admin" asp-action="Index" style="font-size: 1rem; color: #38bdf8; letter-spacing: 0.5px;">
            <i class="fa-solid fa-dumbbell me-2"></i>Fitness Admin
        </a>
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0 text-white-50" id="sidebarToggle" href="#!"><i class="fas fa-bars"></i></button>

        <div class="d-none d-md-inline-block form-inline ms-auto me-0 me-md-3 my-2 my-md-0"></div>

        <ul class="navbar-nav ms-auto ms-md-0 me-3 me-lg-4">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle btn border-0 text-white-50 px-3 rounded-pill" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user-circle fa-lg"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow dropdown-menu-dark" style="background-color: #1e2533; border: 1px solid #2d3748;" aria-labelledby="navbarDropdown">
                    <li><a class="dropdown-item py-2" href="#!"><i class="fa-solid fa-gear me-2 text-info"></i>Ayarlar</a></li>
                    <li><hr class="dropdown-divider my-1" style="border-color: #2d3748;" /></li>
                    <li><a class="dropdown-item py-2 text-danger" href="/"><i class="fa-solid fa-right-from-bracket me-2"></i>Çıkış Yap</a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion" style="background-color: #1e2533; border-right: 1px solid #2d3748;">
                <div class="sb-sidenav-menu">
                    <div class="nav px-2">

                        <div class="sidebar-header-box p-3 my-3 rounded-3" style="background-color: #242f41; border: 1px solid #2d3748;">
                            <h6 class="fw-bold m-0 text-info" style="font-size: 0.9rem;">Yönetim Paneli</h6>
                            <p class="m-0 text-white-50 mt-1" style="font-size: 0.75rem; line-height: 1.3;">Sistem operasyonları ve canlı metrikler.</p>
                        </div>

                        <div class="sb-sidenav-menu-heading text-uppercase text-muted fw-bold ps-2" style="font-size: 0.65rem; letter-spacing: 1px;">Modüller</div>

                        <a class="nav-link rounded px-3 py-2 mb-1 text-white-50 d-flex align-items-center" asp-controller="Rapor" asp-action="Index">
                            <div class="sb-nav-link-icon text-info me-2"><i class="fas fa-chart-line fa-fw"></i></div>
                            <span>Rapor Sayfası</span>
                        </a>

                        <a class="nav-link rounded px-3 py-2 mb-1 text-white-50 d-flex align-items-center" asp-controller="Uye" asp-action="Index">
                            <div class="sb-nav-link-icon text-primary me-2"><i class="fas fa-users fa-fw"></i></div>
                            <span>Üye İşlemleri</span>
                        </a>

                        <a class="nav-link rounded px-3 py-2 mb-1 text-white-50 d-flex align-items-center" asp-controller="Antrenor" asp-action="Index">
                            <div class="sb-nav-link-icon text-purple me-2"><i class="fas fa-dumbbell fa-fw"></i></div>
                            <span>Antrenör İşlemleri</span>
                        </a>

                        <a class="nav-link rounded px-3 py-2 mb-1 text-white-50 d-flex align-items-center" asp-controller="Salon" asp-action="Index">
                            <div class="sb-nav-link-icon text-warning me-2"><i class="fas fa-building fa-fw"></i></div>
                            <span>Salon İşlemleri</span>
                        </a>

                        <a class="nav-link rounded px-3 py-2 mb-1 text-white-50 d-flex align-items-center" asp-controller="Supplement" asp-action="Index">
                            <div class="sb-nav-link-icon text-success me-2"><i class="fas fa-capsules fa-fw"></i></div>
                            <span>Supplement İşlemleri</span>
                        </a>

                    </div>
                </div>
                <div class="sb-sidenav-footer text-white-50" style="background-color: #161b26; border-top: 1px solid #2d3748;">
                    <div class="small opacity-50">Giriş Yapan:</div>
                    <span class="text-white fw-semibold" style="font-size: 0.8rem;"><i class="fa-solid fa-user-shield text-info me-1"></i> Yönetici / Admin</span>
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content" class="d-flex flex-column" style="height: calc(100vh - 56px); overflow: hidden;">
            <main class="flex-grow-1" style="overflow-y: auto; overflow-x: hidden; height: 100%;">
                <div class="container-fluid px-4 pt-3">
                    @RenderBody()
                </div>
            </main>
            <footer class="py-3 mt-auto border-top text-white-50" style="background-color: #1e2533; border-color: #2d3748 !important;">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div>Copyright &copy; Fitness Center 2026</div>
                        <div class="opacity-70">v1.2.0 Canlı Panel</div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/admintemplate/js/scripts.js"></script>
    <script src="~/admintemplate/js/datatables-simple-demo.js"></script>
</body>
</html>

<style>
    .sb-sidenav-dark .sb-sidenav-menu .nav .nav-link:hover {
    color: #ffffff !important;
    background-color: rgba(255, 255, 255, 0.05);
    }

    .text-purple {
    color: #c084fc !important;
    }

    ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
    }

    ::-webkit-scrollbar-track {
    background: transparent;
    }

    ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    }
</style>
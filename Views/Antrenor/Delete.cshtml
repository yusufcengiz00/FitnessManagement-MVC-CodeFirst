@model Project1.Models.Antrenor

@{
    ViewData["Title"] = "Antrenör Sil";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-danger">Antrenör Silme Onayı</h2>
    <h3>Bu antrenörü silmek istediğinizden emin misiniz?</h3>
    <hr />

    <div class="card col-md-6 p-3">
        <p><strong>Adı:</strong> @Model.userName</p>
        <p><strong>Soyadı:</strong> @Model.Yas</p>
        <p><strong>Yaşı:</strong> @Model.TecrübeYili</p>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="AntrenorID" />
            <input type="hidden" asp-for="UyeID" />
            <button type="submit" class="btn btn-danger">Evet, Sil</button>
            <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
        </form>
    </div>
</div>
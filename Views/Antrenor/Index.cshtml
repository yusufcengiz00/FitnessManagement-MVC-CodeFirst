@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Antrenör Listesi";
}

@model IEnumerable<Project1.Models.Antrenor>

<div class="page-header">
    <div>
        <h1 class="page-title">
            <div class="admin-nav-icon icon-purple" style="width:38px;height:38px;border-radius:10px;font-size:1rem;">
                <i class="fa-solid fa-dumbbell"></i>
            </div>
            Antrenör Kadrosu
        </h1>
        <p class="page-subtitle">Eğitmenleri, uzmanlık yaşlarını ve tecrübe sürelerini yönetin.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <a asp-controller="Antrenor" asp-action="ExportToPdf" class="btn export-btn-pdf">
            <i class="fa fa-file-pdf me-1"></i>PDF
        </a>
        <a asp-controller="Antrenor" asp-action="ExportToExcel" class="btn export-btn-excel">
            <i class="fa fa-file-excel me-1"></i>Excel
        </a>
        <a asp-action="Create" class="btn" style="background:linear-gradient(135deg,#6e40c9,#8957e5);color:white;border:none;border-radius:8px;padding:9px 18px;font-weight:600;font-size:0.875rem;">
            <i class="fa-solid fa-user-plus me-2"></i>Yeni Antrenör Ekle
        </a>
    </div>
</div>

<div class="dark-search-card">
    <form asp-action="Index" method="get">
        <div class="d-flex align-items-center gap-2">
            <div class="input-group dark-input-group" style="max-width:420px;">
                <span class="input-group-text">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" name="searchString" class="form-control"
                       placeholder="Antrenörün kullanıcı adı..." value="@ViewBag.CurrentFilter" />
                <button class="btn" type="submit" style="background:rgba(188,140,255,0.1);border:1px solid rgba(188,140,255,0.25);color:#d2a8ff;font-size:0.85rem;padding:0 16px;">
                    Ara
                </button>
                @if (!String.IsNullOrEmpty(ViewBag.CurrentFilter))
                {
                    <a asp-action="Index" class="btn" style="background:rgba(139,148,158,0.1);border:1px solid #30363d;color:#8b949e;">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                }
            </div>
        </div>
    </form>
</div>

<div class="dark-card overflow-hidden">
    <div class="table-responsive">
        <table class="table dark-table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Kullanıcı Adı</th>
                    <th class="text-center">Yaş</th>
                    <th class="text-center">Tecrübe Yılı</th>
                    <th class="text-center">Özel Üye</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var antrenor in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-dark icon-purple" style="background:rgba(188,140,255,0.12);">
                                        @(string.IsNullOrEmpty(antrenor.userName) ? "A" : antrenor.userName.Substring(0, 1).ToUpper())
                                    </div>
                                    <span style="color:#e6edf3;font-weight:600;">@antrenor.userName</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge-dark-age">@antrenor.Yas Yaş</span>
                            </td>
                            <td class="text-center">
                                <span class="badge-dark-exp">
                                    <i class="fa-solid fa-star me-1" style="font-size:0.7rem;"></i>@antrenor.TecrübeYili Yıl
                                </span>
                            </td>
                            <td class="text-center">
                                <span style="color:#8b949e;font-size:0.875rem;">@antrenor.uyeler?.UyeAdi</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@antrenor.AntrenorID" class="btn btn-dark-edit">
                                        <i class="fa-solid fa-pen-to-square me-1"></i>Güncelle
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@antrenor.AntrenorID" class="btn btn-dark-delete">
                                        <i class="fa-solid fa-trash me-1"></i>Sil
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="fa-solid fa-user-ninja fa-2x d-block mb-3" style="color:#30363d;"></i>
                            <span style="color:#6e7681;font-size:0.875rem;">Aradığınız kriterlere uygun antrenör bulunamadı.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>